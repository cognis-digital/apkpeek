<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.example.bankspy"
    android:versionCode="42"
    android:versionName="3.1.0">

    <uses-sdk android:minSdkVersion="19" android:targetSdkVersion="28" />

    <!-- A banking-trojan-shaped permission set -->
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.RECEIVE_SMS" />
    <uses-permission android:name="android.permission.READ_SMS" />
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.BIND_ACCESSIBILITY_SERVICE" />
    <uses-permission android:name="android.permission.BIND_NOTIFICATION_LISTENER_SERVICE" />
    <uses-permission android:name="android.permission.REQUEST_INSTALL_PACKAGES" />
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.READ_CONTACTS" />

    <!-- A custom permission with weak protection level -->
    <permission android:name="com.example.bankspy.C2_CALLBACK"
        android:protectionLevel="normal" />

    <application
        android:label="WeatherPlus"
        android:debuggable="true"
        android:allowBackup="true"
        android:usesCleartextTraffic="true"
        android:networkSecurityConfig="@xml/network_security_config">

        <activity android:name=".MainActivity" android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- StrandHogg-style task hijack setup -->
        <activity android:name=".PhishOverlayActivity"
            android:exported="true"
            android:launchMode="singleTask"
            android:taskAffinity="com.android.settings" />

        <activity android:name=".PrivateActivity" android:exported="false" />

        <!-- Exported provider with no guard, grants URI perms -->
        <provider
            android:name=".ExfilProvider"
            android:authorities="com.example.bankspy.exfil"
            android:exported="true"
            android:grantUriPermissions="true" />

        <!-- Implicitly exported receiver (intent-filter, no android:exported) -->
        <receiver android:name=".SmsInterceptor">
            <intent-filter android:priority="999">
                <action android:name="android.provider.Telephony.SMS_RECEIVED" />
            </intent-filter>
        </receiver>

        <!-- Exported service guarded by permission (should be low severity) -->
        <service android:name=".SyncService" android:exported="true"
            android:permission="com.example.bankspy.C2_CALLBACK" />

    </application>
</manifest>
